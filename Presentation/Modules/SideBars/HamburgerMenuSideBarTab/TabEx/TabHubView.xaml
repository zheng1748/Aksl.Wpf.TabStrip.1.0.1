<UserControl x:Class="Aksl.Tabs.Views.TabHubView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ei="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:views="clr-namespace:Aksl.Tabs.Views"
             xmlns:viewmodels="clr-namespace:Aksl.Tabs.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800"
             prism:ViewModelLocator.AutoWireViewModel="True">
    <UserControl.Resources>

    
    </UserControl.Resources>

    <Grid Background="WhiteSmoke">
        <Grid.RowDefinitions>
            <RowDefinition Height="50" />
            <RowDefinition Height="8" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <views:TabHeaderView DataContext="{Binding Path=TabHeaderViewModel}"
                                 HorizontalAlignment="Stretch"
                                 VerticalAlignment="Stretch" />
        </Grid>

        <Separator Grid.Row="1"
                   Margin="0,1,0,0"
                   Height="8"
                   HorizontalAlignment="Stretch"
                   BorderBrush="#193441" />
        <!--<GridSplitter  Grid.Row="1"
                      Margin="0,1,0,0" HorizontalAlignment="Stretch"
                      BorderBrush="#193441" />-->

        <!--<Border Margin="0"
               Background="WhiteSmoke"
               HorizontalAlignment="Stretch"
               BorderThickness="2"
               CornerRadius="5"
               BorderBrush="Black">-->

        <Grid Grid.Row="2"
              Margin="2"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch">
            <views:TabContentView DataContext="{Binding Path=TabContentViewModel}" />
        </Grid>

        <!--<ContentControl Grid.Row="2"
                        Margin="2"
                        Content="{Binding ViewElement,Mode=OneWay}">
              
            <ContentControl.RenderTransform>
                <TransformGroup>
                    <ScaleTransform />
                    <SkewTransform />
                    <RotateTransform />
                    <TranslateTransform />
                </TransformGroup>
            </ContentControl.RenderTransform>
        </ContentControl>-->
        <!--</Border>-->
    </Grid>
</UserControl>
