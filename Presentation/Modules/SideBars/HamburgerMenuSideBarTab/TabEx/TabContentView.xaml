<UserControl x:Class="Aksl.Tabs.Views.TabContentView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ei="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:views="clr-namespace:Aksl.Tabs.Views"
             xmlns:viewmodels="clr-namespace:Aksl.Tabs.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800">
    <UserControl.Resources>

        <ItemsPanelTemplate x:Key="tabContentItemsPanelTemplate">
            <WrapPanel Width="Auto"
                       Orientation="Horizontal" />
        </ItemsPanelTemplate>

        <DataTemplate x:Key="tabContentDataTemplate"
                      DataType="{x:Type viewmodels:TabContentItemViewModel}">
            <views:TabContentItemView />
        </DataTemplate>

    </UserControl.Resources>

    <ItemsControl ItemsSource="{Binding Path=TabContentItems}"
                  ItemContainerStyle="{Binding Source={StaticResource tabContentItemsPanelTemplate}}"
                  ItemTemplate="{Binding Source={StaticResource tabContentDataTemplate}}"
                  Background="Transparent">
    </ItemsControl>

</UserControl>
